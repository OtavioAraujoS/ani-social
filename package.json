{
  "name": "ani-social",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/index.ts",
    "db:generate": "bun x drizzle-kit generate",
    "db:migrate": "docker compose exec app bun x drizzle-kit migrate",
    "db:push": "docker compose exec app bun x drizzle-kit push",
    "db:up": "docker compose up -d postgres-db && docker compose up -d --build app && bun run db:migrate",
    "db:down": "docker compose down",
    "db:studio": "bun x drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "cloudinary": "^2.9.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "elysia-rate-limit": "^4.5.1",
    "postgres": "^3.4.8",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "module": "src/index.js"
}
